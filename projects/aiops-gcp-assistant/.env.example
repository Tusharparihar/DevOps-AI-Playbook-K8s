# ─────────────────────────────────────────────────────────────
# Kira — GKE AIOps Assistant  |  Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# 1. GCP PROJECT ID (required)
#    Find it in GCP Console → top dropdown, or run: gcloud config get-value project
GCP_PROJECT_ID=your-gcp-project-id-here

# 2. GCP REGION for Vertex AI Gemini
#    Use a Vertex-supported region where your project has model access.
GCP_REGION=us-central1

# 3. PROMETHEUS URL (optional — needed for fetch_metrics)
#
#    Option A — Port-forward (easiest, run this in a separate terminal):
#      kubectl port-forward svc/prometheus-kube-prometheus-prometheus -n monitoring 9090:9090
#    Then keep PROMETHEUS_URL as http://localhost:9090
#
#    Option B — Expose Prometheus as LoadBalancer:
#      kubectl patch svc prometheus-kube-prometheus-prometheus -n monitoring \
#        -p '{"spec": {"type": "LoadBalancer"}}'
#      kubectl get svc -n monitoring   ← copy the EXTERNAL-IP
#    Then set: PROMETHEUS_URL=http://<EXTERNAL-IP>:9090
#
PROMETHEUS_URL=http://localhost:9090

# 4. GEMINI MODEL on Vertex AI
#    Use the model currently available in this project.
GEMINI_MODEL=gemini-2.5-flash

# 5. Authenticate once on your machine before running app:
#    gcloud auth application-default login
#    (No GEMINI_API_KEY is required for this Vertex setup)
